{
  "name": "@hobt/lego-skirmish",
  "version": "0.1.0",
  "description": "Heroes of Brick & Tactics — LEGO Skirmish rules engine",
  "type": "module",
  "workspaces": [
    "web"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:web": "npm run build -w @hobt/configurator",
    "typecheck": "tsc --noEmit",
    "typecheck:web": "npm run typecheck -w @hobt/configurator",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:web": "npm run dev -w @hobt/configurator"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
